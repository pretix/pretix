{
	"include": ["src/pretix/static/**/*", "src/pretix/static/**/*.vue"],
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
		},
		"strict": false,
		"allowJs": true,
		"checkJs": true,
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"noErrorTruncation": true,
		"noImplicitThis": true,
		"isolatedModules": true,
		"types": ["node", "events"]
	}
}
